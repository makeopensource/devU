# Building the static files needed by client

FROM node:16 as client
# Message to user
ENTRYPOINT echo "Static files from devU-client will be generated"

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm install
COPY . .
RUN npm run build-local

# Starting up nginx
FROM nginx:1.23.3
# Message to user
ENTRYPOINT echo "Nginx is being setup, will be on default port 9000"
COPY  --from=client /app/dist/* /usr/share/nginx/html
# This is bad practice, also port should not be fixed
# This command will store the files in /dist/local that is mounted to the folder of the same name in project
# This is optional, since it should only be used when you want to see the static files generated by client
# CMD cp -r /usr/share/nginx/html/local/html/ /dist/local
